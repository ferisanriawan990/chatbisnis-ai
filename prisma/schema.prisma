generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum KnowledgeSourceType {
  manual
  excel
  csv
  pdf
  docx
  google_sheet
}

enum KnowledgeSourceStatus {
  pending
  processing
  active
  failed
}

enum LeadStatus {
  cold
  warm
  hot
  converted
  lost
}

enum ChatLogStatus {
  success
  failed
}

// ─── Models ──────────────────────────────────────────────

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  passwordHash     String
  role             UserRole          @default(USER)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  businessProfiles BusinessProfile[]
  chatbotSettings  ChatbotSetting[]
  knowledgeSources KnowledgeSource[]
  knowledgeItems   KnowledgeItem[]
  chatLogs         ChatLog[]
  leads            Lead[]
  whatsappSessions WhatsAppSession[]
  subscriptions    Subscription[]
  usageCounters    UsageCounter[]
  auditLogs        AuditLog[]
  conversationStates ConversationState[]
}

model BusinessProfile {
  id                  String            @id @default(uuid())
  userId              String
  businessName        String
  businessIndustry    String
  businessDescription String            @db.Text
  address             String            @db.Text
  openingHours        String
  adminPhone          String
  websiteUrl          String?
  instagramUrl        String?
  marketplaceUrl      String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatbotSettings     ChatbotSetting[]
  knowledgeSources    KnowledgeSource[]
  knowledgeItems      KnowledgeItem[]
  chatLogs            ChatLog[]
  leads               Lead[]
  whatsappSessions    WhatsAppSession[]
  usageCounters       UsageCounter[]
  conversationStates  ConversationState[]
}

model ChatbotSetting {
  id                    String          @id @default(uuid())
  userId                String
  businessProfileId     String
  botName               String
  isActive              Boolean         @default(false)
  toneStyle             String          @default("Profesional")
  language              String          @default("id")
  useEmoji              Boolean         @default(true)
  maxReplyLength        String          @default("sedang")
  allowSelling          Boolean         @default(true)
  allowPromoOffer       Boolean         @default(true)
  fallbackMessage       String          @db.Text
  handoverMessage       String          @db.Text
  handoverKeywords      String          @db.Text
  outOfHoursMessage     String          @db.Text
  aiProvider            String          @default("Flaz Cloud")
  aiModel               String          @default("claude-haiku-4-5")
  aiApiKeyEncrypted     String?
  dailyChatLimit        Int             @default(1000)
  monthlyChatLimit      Int             @default(30000)
  wahaBaseUrl           String?
  wahaApiKeyEncrypted   String?
  wahaServerId          String?
  wahaSessionName       String          @unique
  n8nWebhookUrl         String?
  internalWebhookSecret String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile       BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  wahaServer            WahaServer?     @relation(fields: [wahaServerId], references: [id], onDelete: SetNull)
  chatLogs              ChatLog[]
  whatsappSessions      WhatsAppSession[]
  conversationStates    ConversationState[]
}

model KnowledgeSource {
  id                String                @id @default(uuid())
  userId            String
  businessProfileId String
  type              KnowledgeSourceType
  title             String
  originalFileName  String?
  fileUrl           String?
  googleSheetUrl    String?
  websiteUrl        String?
  status            KnowledgeSourceStatus @default(pending)
  errorMessage      String?               @db.Text
  itemCount         Int                   @default(0)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  knowledgeItems    KnowledgeItem[]

  @@index([userId, businessProfileId, status])
}

model KnowledgeItem {
  id                String          @id @default(uuid())
  userId            String
  businessProfileId String
  sourceId          String?
  category          String?
  question          String?         @db.Text
  answer            String?         @db.Text
  productName       String?
  productCategory   String?
  price             Float?
  stockStatus       String?
  description       String?         @db.Text
  metadataJson      String?         @db.Text
  searchableText    String          @db.Text
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  source            KnowledgeSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([userId, businessProfileId, sourceId, isActive])
}

model ChatLog {
  id                String          @id @default(uuid())
  userId            String
  businessProfileId String
  chatbotSettingId  String
  customerPhone     String
  customerName      String?
  messageIn         String          @db.Text
  messageOut        String?         @db.Text
  intent            String?
  aiUsed            String?
  status            ChatLogStatus   @default(success)
  errorMessage      String?         @db.Text
  needsHuman        Boolean         @default(false)
  tokenUsage        Int             @default(0)
  createdAt         DateTime        @default(now())

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  chatbotSetting    ChatbotSetting  @relation(fields: [chatbotSettingId], references: [id], onDelete: Cascade)

  @@index([userId, businessProfileId, chatbotSettingId, createdAt])
  @@index([customerPhone, createdAt])
}

model Lead {
  id                String          @id @default(uuid())
  userId            String
  businessProfileId String
  customerPhone     String
  customerName      String?
  interest          String?
  budget            Float?
  address           String?         @db.Text
  status            LeadStatus      @default(cold)
  notes             String?         @db.Text
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@unique([businessProfileId, customerPhone])
  @@index([userId, businessProfileId, status, createdAt])
}

model WhatsAppSession {
  id                String          @id @default(uuid())
  userId            String
  businessProfileId String
  chatbotSettingId  String
  wahaServerId      String?
  sessionName       String          @unique
  status            String          @default("disconnected") // disconnected, starting, qr, connected, failed
  lastConnectedAt   DateTime?
  lastError         String?         @db.Text
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  chatbotSetting    ChatbotSetting  @relation(fields: [chatbotSettingId], references: [id], onDelete: Cascade)
  wahaServer        WahaServer?     @relation(fields: [wahaServerId], references: [id], onDelete: SetNull)
}

// ─── Admin & System Models ───────────────────────────────

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string")
  description String?  @db.Text
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SecretCredential {
  id             String    @id @default(uuid())
  name           String
  key            String    @unique
  encryptedValue String    @db.Text
  provider       String
  description    String?   @db.Text
  isActive       Boolean   @default(true)
  lastRotatedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model WahaServer {
  id              String   @id @default(uuid())
  name            String
  baseUrl         String
  apiKeyEncrypted String?  @db.Text
  status          String   @default("active")
  maxSessions     Int      @default(50)
  currentSessions Int      @default(0)
  isActive        Boolean  @default(true)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  chatbotSettings ChatbotSetting[]
  whatsappSessions WhatsAppSession[]
}

model Plan {
  id                  String   @id @default(uuid())
  name                String
  slug                String   @unique
  priceMonthly        Float    @default(0)
  maxWhatsappSessions Int      @default(1)
  maxKnowledgeItems   Int      @default(50)
  dailyChatLimit      Int      @default(100)
  monthlyChatLimit    Int      @default(3000)
  allowN8nTemplates   Boolean  @default(false)
  allowLeadCapture    Boolean  @default(false)
  allowHumanHandover  Boolean  @default(false)
  allowCustomApiKey   Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  subscriptions       Subscription[]
}

model Subscription {
  id        String    @id @default(uuid())
  userId    String    @unique
  planId    String
  status    String    @default("active")
  startedAt DateTime  @default(now())
  expiredAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model UsageCounter {
  id                String   @id @default(uuid())
  userId            String
  businessProfileId String?
  date              DateTime @db.Date
  month             String   
  aiChats           Int      @default(0)
  aiTokens          Int      @default(0)
  whatsappMessages  Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)

  @@unique([userId, date])
  @@index([userId, month])
}

model AuditLog {
  id           String   @id @default(uuid())
  actorUserId  String?
  action       String
  entityType   String
  entityId     String?
  metadataJson String?  @db.Text
  ipAddress    String?
  userAgent    String?  @db.Text
  createdAt    DateTime @default(now())

  actorUser User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
}

model ConversationState {
  id                String          @id @default(uuid())
  userId            String
  businessProfileId String
  chatbotSettingId  String
  customerPhone     String
  status            String          @default("ai_active") // ai_active or human_handover
  handoverUntil     DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  chatbotSetting    ChatbotSetting  @relation(fields: [chatbotSettingId], references: [id], onDelete: Cascade)

  @@unique([chatbotSettingId, customerPhone])
  @@index([userId, businessProfileId, status])
}
