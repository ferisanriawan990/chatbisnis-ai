generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum KnowledgeSourceType {
  manual
  excel
  csv
  pdf
  docx
  google_sheet
  web_scraping
}

enum KnowledgeSourceStatus {
  pending
  processing
  active
  failed
}

enum LeadStatus {
  cold
  warm
  hot
  converted
  lost
}

enum ChatLogStatus {
  success
  failed
}

// ─── Models ──────────────────────────────────────────────

model User {
  id                    String               @id @default(uuid())
  name                  String
  email                 String               @unique
  passwordHash          String
  role                  UserRole             @default(USER)
  twoFactorSecret       String?
  twoFactorEnabled      Boolean              @default(false)
  lastSeenAt            DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  businessProfiles      BusinessProfile[]
  chatbotSettings       ChatbotSetting[]
  knowledgeSources      KnowledgeSource[]
  knowledgeItems        KnowledgeItem[]
  chatLogs              ChatLog[]
  leads                 Lead[]               @relation("OwnerLeads")
  assignedLeads         Lead[]               @relation("AssignedLeadAdmin")
  whatsappSessions      WhatsAppSession[]
  subscriptions         Subscription[]
  usageCounters         UsageCounter[]
  auditLogs             AuditLog[]
  conversationStates    ConversationState[]
  assignedConversations ConversationState[]  @relation("AssignedAdmin")
  Transaction           Transaction[]
  botConfig             BusinessBotConfig?
  userRoleAssignments   UserRoleAssignment[]
}

model BusinessProfile {
  id                  String   @id @default(uuid())
  userId              String
  businessName        String
  businessIndustry    String
  businessDescription String   @db.Text
  address             String   @db.Text
  openingHours        String
  adminPhone          String
  websiteUrl          String?
  instagramUrl        String?
  marketplaceUrl      String?
  customLinks         String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  chatRetentionDays   Int      @default(0) // 0 means keep forever

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatbotSettings       ChatbotSetting[]
  knowledgeSources      KnowledgeSource[]
  knowledgeItems        KnowledgeItem[]
  chatLogs              ChatLog[]
  leads                 Lead[]
  campaigns             Campaign[]
  quickReplies          QuickReply[]
  whatsappSessions      WhatsAppSession[]
  usageCounters         UsageCounter[]
  conversationStates    ConversationState[]
  branches              Branch[]
  roles                 Role[]
  userRoleAssignments   UserRoleAssignment[]
  tenantFeatureSettings TenantFeatureSetting[]
  products              Product[]
  orders                Order[]
  broadcasts            BroadcastCampaign[]
  bookings              Booking[]
  Testimonial           Testimonial[]
  vouchers              Voucher[]
  auditLogs             AuditLog[]
}

model ChatbotSetting {
  id                      String   @id @default(uuid())
  userId                  String
  businessProfileId       String
  botName                 String
  isActive                Boolean  @default(false)
  toneStyle               String   @default("Profesional")
  language                String   @default("id")
  useEmoji                Boolean  @default(true)
  maxReplyLength          String   @default("sedang")
  allowSelling            Boolean  @default(true)
  allowPromoOffer         Boolean  @default(true)
  allowVision             Boolean  @default(false)
  allowVoiceNote          Boolean  @default(false)
  fallbackMessage         String   @db.Text
  handoverMessage         String   @db.Text
  handoverKeywords        String   @db.Text
  outOfHoursMessage       String   @db.Text
  aiProvider              String   @default("Flaz Cloud")
  aiModel                 String   @default("claude-haiku-4-5")
  dailyChatLimit          Int      @default(1000)
  monthlyChatLimit        Int      @default(30000)
  historyMessageCount     Int      @default(6)
  knowledgeCharLimit      Int      @default(3500)
  actionWebhookUrl        String?
  whatsappBaseUrl         String?
  whatsappApiKeyEncrypted String?
  whatsappServerId        String?
  whatsappSessionName     String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile    BusinessProfile     @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  whatsappServer     WhatsappServer?     @relation(fields: [whatsappServerId], references: [id], onDelete: SetNull)
  chatLogs           ChatLog[]
  whatsappSessions   WhatsAppSession[]
  conversationStates ConversationState[]

  @@unique([whatsappServerId, whatsappSessionName])
}

model KnowledgeSource {
  id                String                @id @default(uuid())
  userId            String
  businessProfileId String
  type              KnowledgeSourceType
  title             String
  originalFileName  String?
  fileUrl           String?
  googleSheetUrl    String?
  websiteUrl        String?
  status            KnowledgeSourceStatus @default(pending)
  errorMessage      String?               @db.Text
  itemCount         Int                   @default(0)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  knowledgeItems  KnowledgeItem[]

  @@index([userId, businessProfileId, status])
}

model KnowledgeItem {
  id                String   @id @default(uuid())
  userId            String
  businessProfileId String
  sourceId          String?
  category          String?
  question          String?  @db.Text
  answer            String?  @db.Text
  productName       String?
  productCategory   String?
  price             Float?
  stockStatus       String?
  description       String?  @db.Text
  imageUrl          String?  @db.Text
  metadataJson      String?  @db.Text
  searchableText    String   @db.Text
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile BusinessProfile  @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  source          KnowledgeSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([userId, businessProfileId, sourceId, isActive])
}

model ChatLog {
  id                String        @id @default(uuid())
  userId            String
  businessProfileId String
  chatbotSettingId  String
  customerPhone     String
  customerName      String?
  messageIn         String        @db.Text
  messageOut        String?       @db.Text
  intent            String?
  aiUsed            String?
  status            ChatLogStatus @default(success)
  errorMessage      String?       @db.Text
  metadataJson      String?       @db.Text
  needsHuman        Boolean       @default(false)
  tokenUsage        Int           @default(0)
  createdAt         DateTime      @default(now())

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  chatbotSetting  ChatbotSetting  @relation(fields: [chatbotSettingId], references: [id], onDelete: Cascade)

  @@index([userId, businessProfileId, chatbotSettingId, createdAt])
  @@index([customerPhone, createdAt])
}

model Lead {
  id                String     @id @default(uuid())
  userId            String
  businessProfileId String
  customerPhone     String
  customerName      String?
  interest          String?
  budget            Float?
  address           String?    @db.Text
  status            LeadStatus @default(cold)
  notes             String?    @db.Text
  tags              String?    @db.Text
  leadScore         Int?       // 1-100 score of purchase intent
  churnReason       String?    @db.Text // Alasan kegagalan closing
  loyaltyPoints     Int        @default(0)
  isReturning       Boolean    @default(false)
  isOptedOut        Boolean    @default(false)
  birthDate         DateTime?
  lastActiveAt      DateTime?  @default(now())
  followUpDate      DateTime?
  followUpStatus    String?    @default("pending") // pending, contacted, closing, cancelled
  assignedAdminId   String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user            User            @relation("OwnerLeads", fields: [userId], references: [id], onDelete: Cascade)
  assignedAdmin   User?           @relation("AssignedLeadAdmin", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  campaignTargets CampaignTarget[]

  @@unique([businessProfileId, customerPhone])
  @@index([userId, businessProfileId, status, createdAt])
}

model WhatsAppSession {
  id                String    @id @default(uuid())
  userId            String
  businessProfileId String
  chatbotSettingId  String
  whatsappServerId  String?
  sessionName       String
  status            String    @default("disconnected") // disconnected, starting, qr, connected, failed
  lastConnectedAt   DateTime?
  lastError         String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  chatbotSetting  ChatbotSetting  @relation(fields: [chatbotSettingId], references: [id], onDelete: Cascade)
  whatsappServer  WhatsappServer? @relation(fields: [whatsappServerId], references: [id], onDelete: SetNull)

  @@unique([whatsappServerId, sessionName])
}

// ─── Admin & System Models ───────────────────────────────

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string")
  description String?  @db.Text
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SecretCredential {
  id             String    @id @default(uuid())
  name           String
  key            String    @unique
  encryptedValue String    @db.Text
  provider       String
  description    String?   @db.Text
  isActive       Boolean   @default(true)
  lastRotatedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model WhatsappServer {
  id                String    @id @default(uuid())
  name              String
  baseUrl           String
  apiKeyEncrypted   String?   @db.Text
  status            String    @default("active")
  maxSessions       Int       @default(50)
  currentSessions   Int       @default(0)
  isActive          Boolean   @default(true)
  notes             String?   @db.Text
  lastHealthCheckAt DateTime?
  lastError         String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  chatbotSettings  ChatbotSetting[]
  whatsappSessions WhatsAppSession[]
}

model Plan {
  id                  String   @id @default(uuid())
  name                String
  slug                String   @unique
  priceMonthly        Float    @default(0)
  maxWhatsappSessions Int      @default(1)
  maxKnowledgeItems   Int      @default(50)
  dailyChatLimit      Int      @default(100)
  monthlyChatLimit    Int      @default(3000)
  allowLeadCapture    Boolean  @default(false)
  allowHumanHandover  Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  subscriptions Subscription[]
  Transaction   Transaction[]
}

model Subscription {
  id        String    @id @default(uuid())
  userId    String    @unique
  planId    String
  status    String    @default("active")
  startedAt DateTime  @default(now())
  expiredAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model UsageCounter {
  id                String   @id @default(uuid())
  userId            String
  businessProfileId String?
  date              DateTime @db.Date
  month              String
  aiChats            Int      @default(0)
  aiTokens           Int      @default(0)
  whatsappMessages   Int      @default(0)
  dailyWarningSent   Boolean  @default(false)
  monthlyWarningSent Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)

  @@unique([userId, date])
  @@index([userId, month])
}

model AuditLog {
  id                String   @id @default(uuid())
  actorUserId       String?
  businessProfileId String?
  action            String
  entityType        String
  entityId          String?
  metadataJson      String?  @db.Text
  ipAddress         String?
  userAgent         String?  @db.Text
  createdAt         DateTime @default(now())

  actorUser       User?            @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  businessProfile BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt])
  @@index([businessProfileId, createdAt])
  @@index([entityType, entityId])
}

model ConversationState {
  id                String    @id @default(uuid())
  userId            String
  businessProfileId String
  chatbotSettingId  String
  customerPhone     String
  customerName      String?
  status            String    @default("ai_active") // ai_active, human_handover, waiting_admin
  handoverUntil     DateTime?
  unreadCount       Int       @default(0)
  lastMessageAt     DateTime  @default(now())
  sentimentScore    String? // positif, netral, negatif, marah
  summary           String?   @db.Text
  assignedAdminId   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAdmin   User?           @relation("AssignedAdmin", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  chatbotSetting  ChatbotSetting  @relation(fields: [chatbotSettingId], references: [id], onDelete: Cascade)

  @@unique([chatbotSettingId, customerPhone])
  @@index([userId, businessProfileId, status])
  @@index([businessProfileId, lastMessageAt])
}

model Transaction {
  id              String    @id @default(uuid())
  userId          String
  planId          String
  amount          Float
  status          String    @default("pending") // pending, paid, failed, expired
  paymentProvider String?
  externalId      String?   @unique
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// ─── Business Template System ────────────────────────────

model BusinessTemplate {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  category        String
  description     String   @db.Text
  systemPrompt    String   @db.Text
  requiredFields  String   @db.Text // JSON array of required field names
  sampleQuestions String   @db.Text // JSON array of sample customer questions
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  botConfigs BusinessBotConfig[]
}

model BusinessBotConfig {
  id                  String   @id @default(uuid())
  userId              String   @unique
  templateId          String?
  businessName        String
  businessDescription String   @db.Text
  productsOrServices  String?  @db.Text // JSON array or free text
  pricingInfo         String?  @db.Text
  operationalHours    String?
  address             String?  @db.Text
  serviceArea         String?
  paymentMethods      String?
  deliveryMethods     String?
  humanAdminContact   String?
  catalogUrl          String?
  mapsUrl             String?
  customFAQ           String?  @db.Text // JSON array [{q, a}]
  tone                String   @default("sopan")
  languageStyle       String   @default("id")
  botMode             String   @default("auto_reply")
  isBotActive         Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template BusinessTemplate? @relation(fields: [templateId], references: [id])
}

// ─── Multi-Tenant & RBAC ─────────────────────────────────

model Branch {
  id                String   @id @default(uuid())
  businessProfileId String
  name              String
  address           String?  @db.Text
  phone             String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([businessProfileId])
}

model Testimonial {
  id                String   @id @default(uuid())
  businessProfileId String
  orderId           String?  @unique
  customerName      String?
  customerPhone     String?
  rating            Int // 1 to 5
  reviewText        String?  @db.Text
  isPublished       Boolean  @default(false)
  createdAt         DateTime @default(now())

  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
}

model Role {
  id                String   @id @default(uuid())
  businessProfileId String? // If null, it's a global system role. If set, it's a tenant-specific custom role.
  name              String
  description       String?
  isSystem          Boolean  @default(false) // System roles cannot be deleted
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  businessProfile BusinessProfile?     @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  permissions     RolePermission[]
  userRoles       UserRoleAssignment[]

  @@index([businessProfileId])
}

model Permission {
  id          String   @id @default(uuid())
  action      String   @unique // e.g., 'whatsapp.view', 'customer.create'
  description String?
  module      String // e.g., 'whatsapp', 'customer', 'order'
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
}

model UserRoleAssignment {
  id                String   @id @default(uuid())
  userId            String
  businessProfileId String?
  roleId            String
  createdAt         DateTime @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  role            Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, businessProfileId, roleId])
  @@index([userId])
  @@index([businessProfileId])
}

model Product {
  id                String  @id @default(uuid())
  businessProfileId String
  name              String
  description       String? @db.Text
  price             Decimal @default(0.0)
  stock             Int     @default(0)
  isAvailable       Boolean @default(true)
  imageUrl          String?
  category          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]

  @@index([businessProfileId])
}

// ─── E-Commerce & Shopping Cart ──────────────────────────

model Order {
  id                String      @id @default(uuid())
  businessProfileId String
  customerPhone     String
  customerName      String?
  orderNumber       String      @unique
  status            String      @default("draft") // draft, pending_payment, dp_paid, paid, processing, shipped, completed, cancelled
  totalAmount       Decimal     @default(0.0)
  dpAmount          Decimal     @default(0.0)
  dpPaidAt          DateTime?
  notes             String?     @db.Text
  shippingAddress   String?     @db.Text
  shippingCourier   String?
  shippingResi      String?
  shippingFee       Decimal     @default(0.0)
  discountAmount    Decimal     @default(0.0)
  voucherCode       String?
  deliveryMethod    String      @default("shipping") // shipping, pickup
  reminderSentAt    DateTime?
  items             OrderItem[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([businessProfileId, customerPhone])
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  productId   String?
  productName String
  quantity    Int     @default(1)
  price       Decimal @default(0.0)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

// ─── Broadcast & Marketing ───────────────────────────────

model BroadcastCampaign {
  id                String    @id @default(uuid())
  businessProfileId String
  name              String
  messageTemplate   String    @db.Text
  targetTags        String?   @db.Text
  status            String    @default("draft") // draft, scheduled, processing, completed, failed
  scheduledAt       DateTime?
  completedAt       DateTime?
  imageUrl          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  businessProfile BusinessProfile      @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  recipients      BroadcastRecipient[]

  @@index([businessProfileId, status])
}

model BroadcastRecipient {
  id            String    @id @default(uuid())
  campaignId    String
  customerPhone String
  customerName  String?
  status        String    @default("pending") // pending, sent, failed
  errorMessage  String?   @db.Text
  sentAt        DateTime?

  campaign BroadcastCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
}

// ─── Feature Flags ───────────────────────────────────────

model FeatureDefinition {
  id          String   @id @default(uuid())
  key         String   @unique // e.g. 'whatsapp_broadcast', 'ai_vision'
  name        String
  description String?  @db.Text
  module      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenantSettings TenantFeatureSetting[]
}

model TenantFeatureSetting {
  id                String   @id @default(uuid())
  businessProfileId String
  featureId         String
  isEnabled         Boolean  @default(true)
  limitCount        Int? // If the feature has a quota
  configJson        String?  @db.Text
  updatedBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  businessProfile BusinessProfile   @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  feature         FeatureDefinition @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([businessProfileId, featureId])
  @@index([businessProfileId])
}

model Booking {
  id                String   @id @default(uuid())
  businessProfileId String
  customerPhone     String
  customerName      String?
  serviceName       String // Misal: "Konsultasi Dokter", "Potong Rambut"
  bookingDate       DateTime
  status            String   @default("pending") // pending, confirmed, cancelled, completed
  notes             String?  @db.Text
  reminderSentAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([businessProfileId])
  @@index([customerPhone])
}

model Voucher {
  id                String   @id @default(uuid())
  businessProfileId String
  code              String   
  discountType      String   // "percentage" | "fixed"
  discountValue     Float
  minPurchase       Float?   @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  
  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  
  @@index([businessProfileId, code])
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
}

enum CampaignType {
  MANUAL
  BIRTHDAY_AUTO
  RETARGETING_AUTO
}

enum CampaignTargetStatus {
  PENDING
  SENT
  FAILED
  OPT_OUT
}

model Campaign {
  id                String         @id @default(uuid())
  businessProfileId String
  name              String
  type              CampaignType   @default(MANUAL)
  messageTemplate   String         @db.Text
  status            CampaignStatus @default(DRAFT)
  scheduledAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  businessProfile   BusinessProfile  @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  targets           CampaignTarget[]

  @@index([businessProfileId, status])
}

model CampaignTarget {
  id           String               @id @default(uuid())
  campaignId   String
  leadId       String
  status       CampaignTargetStatus @default(PENDING)
  sentAt       DateTime?
  errorReason  String?              @db.Text
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@index([leadId])
  @@unique([campaignId, leadId])
}

model QuickReply {
  id                String   @id @default(uuid())
  businessProfileId String
  title             String
  content           String   @db.Text
  shortcut          String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

