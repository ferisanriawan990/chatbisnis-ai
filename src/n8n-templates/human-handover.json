{
  "name": "Template Human Handover",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "waha-webhook-n8n",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-waha",
      "name": "Webhook WAHA",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [ 100, 300 ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{'{{WEBSITE_API_BASE_URL}}'.replace(/\\/$/, '') + '/api/webhooks/waha'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-webhook-secret",
              "value": "{{WAHA_WEBHOOK_SECRET}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify($json.body || $json) }}"
      },
      "id": "forward-chatbisnis",
      "name": "Forward to ChatBisnis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [ 300, 300 ],
      "onError": "continueErrorOutput"
    }
  ],
  "connections": {
    "Webhook WAHA": {
      "main": [
        [
          {
            "node": "Forward to ChatBisnis",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}