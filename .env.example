# -----------------------------------------------------------------------------
# DANGEROUS WARNING:
# 1. DO NOT COMMIT .env TO REPOSITORY
# 2. ALL SECRETS MUST BE SET IN VERCEL ENVIRONMENT VARIABLES FOR PRODUCTION
# -----------------------------------------------------------------------------

# --- Database Setup ---
# Use Vercel Postgres or Supabase in production.
DATABASE_URL=

# --- NextAuth Setup ---
# Leave empty or set to Vercel domain in production (e.g. https://nama-project.vercel.app)
NEXTAUTH_URL=
# Generate a secure random string for JWT (min 32 chars)
NEXTAUTH_SECRET=

# --- Application URL ---
# The primary domain of your app (e.g. https://chatbisnis.ai). Required for SEO and Webhooks.
NEXT_PUBLIC_APP_URL=

# --- Critical Security ---
# CRITICAL: MUST BE EXACTLY 32 CHARACTERS LONG
# Used for encrypting/decrypting API Keys in the database.
# DANGER: Do not change this after production or old keys will be unrecoverable!
ENCRYPTION_SECRET=

# --- Integrations ---
AI_BASE_URL=
INTERNAL_API_KEY=

# --- Webhook Security ---
# Internal webhook secret for system cron/tasks
INTERNAL_WEBHOOK_SECRET=
# Webhook secret to secure payloads coming from WAHA or n8n.
# MUST BE THE SAME IN BACKEND AND N8N/WAHA FORWARDER.
WAHA_WEBHOOK_SECRET=

# --- Super Admin Credentials ---
# Used ONLY during first setup (scripts/create-admin.ts).
# ADMIN_PASSWORD must be at least 12 characters.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
