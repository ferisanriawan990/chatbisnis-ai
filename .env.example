# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/chatbisnis?schema=public"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-at-least-32-chars"

# Encryption (MUST be exactly 32 characters, DO NOT CHANGE after production)
ENCRYPTION_SECRET="12345678901234567890123456789012"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI Configuration (Fallback)
AI_BASE_URL="https://ai.flaz.id/v1"

# Internal Security (Used for n8n to backend communication)
INTERNAL_API_KEY="your-internal-secure-api-key"

# WAHA Webhook Security
WAHA_WEBHOOK_SECRET="your-waha-webhook-secret-key"

# Initial Super Admin Creation (Used by scripts/create-admin.ts)
ADMIN_EMAIL="admin@chatbisnis.id"
ADMIN_PASSWORD="super-secure-password-min-12-chars"
ADMIN_NAME="Super Admin"
