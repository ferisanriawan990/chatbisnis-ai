# ==========================================
# ChatBisnis AI - Production Environment Variables
# ==========================================

# 1. DATABASE (Wajib)
# URL koneksi ke Database PostgreSQL Anda (misal: Supabase, Neon)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# 2. AUTENTIKASI (Wajib)
# URL Publik aplikasi (misal: https://chatbisnis-ai.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
# Kunci rahasia untuk enkripsi sesi pengguna (Gunakan: openssl rand -base64 32)
NEXTAUTH_SECRET="ganti_dengan_secret_yang_aman_dan_panjang"

# 3. MIDTRANS PAYMENT GATEWAY (Wajib untuk Produksi)
MIDTRANS_SERVER_KEY="SB-Mid-server-..."
MIDTRANS_CLIENT_KEY="SB-Mid-client-..."

# 4. EMAIL SERVICE (Opsional - Jika kosong akan menggunakan mode Terminal Mock)
# Daftar di resend.com dan dapatkan API Key
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"

# 5. LOGISTIK & ONGKIR (Opsional - Jika kosong akan menggunakan mode Simulasi)
# Daftar di rajaongkir.com (Tipe Starter/Basic/Pro)
RAJAONGKIR_API_KEY=""
# ID Kota Asal Pengiriman Bisnis Anda (Default 152 = Jakarta Pusat)
RAJAONGKIR_ORIGIN_ID="152"

# 6. ENKRIPSI WHATSAPP
# Kunci 32 karakter untuk mengenkripsi sesi WhatsApp di database
ENCRYPTION_SECRET="super_secret_encryption_key_32_chars_123"

# 7. CRON JOBS
# Kunci rahasia untuk memanggil endpoint Cron (contoh: /api/cron/broadcast-runner)
CRON_SECRET="ganti_dengan_cron_secret_yang_aman"

# 8. AI PROVIDER (Global Fallback)
# URL endpoint AI (misal: https://ai.flaz.id/v1 atau biarkan kosong untuk OpenAI asli)
AI_BASE_URL="https://ai.flaz.id/v1"
