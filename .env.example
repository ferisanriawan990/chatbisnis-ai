# -----------------------------------------------------------------------------
# DANGEROUS WARNING:
# 1. DO NOT COMMIT .env TO REPOSITORY
# 2. ALL SECRETS MUST BE SET IN ENVIRONMENT VARIABLES FOR PRODUCTION
# -----------------------------------------------------------------------------

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/chatbisnis?schema=public"
DIRECT_URL="" # jika diperlukan untuk koneksi langsung (e.g. Supabase)

# --- Authentication & Security ---
AUTH_SECRET="generate-a-secure-secret-key-with-openssl"
NEXTAUTH_SECRET="generate-a-secure-secret-key-with-openssl"
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
ENCRYPTION_KEY="32-byte-long-secure-encryption-key" # untuk mengenkripsi kredensial
WEBHOOK_SECRET="secret-untuk-memvalidasi-webhook-masuk"
CRON_SECRET="secret-untuk-menjalankan-cron-jobs"

# --- AI Provider (Flaz Cloud) ---
FLAZ_API_KEY="sk-flaz-your-api-key"
FLAZ_BASE_URL="https://ai.flaz.id/v1"
FLAZ_CHAT_MODEL="cgemini-2.5-flash-lite"
FLAZ_VISION_MODEL="gemini-2.5-flash-lite"
FLAZ_TTS_MODEL="tts-1"
FLAZ_STT_MODEL="whisper-1"

# --- WhatsApp Engine ---
WHATSAPP_ENGINE="waha" # waha atau baileys
WAHA_URL="http://localhost:3000"
WAHA_API_KEY="your-waha-secret"

# --- Redis & Task Queue (Opsional) ---
REDIS_URL="redis://localhost:6379"

# --- Storage (Opsional) ---
STORAGE_PROVIDER="s3" # s3, r2, supabase, local
STORAGE_BUCKET="chatbisnis-storage"

# --- Integrations (Opsional) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
PAYMENT_GATEWAY_URL=
PAYMENT_GATEWAY_KEY=
SHIPPING_API_URL=
SHIPPING_API_KEY=

# --- Super Admin Credentials ---
ADMIN_EMAIL="admin@chatbisnis.ai"
ADMIN_PASSWORD="super-secret-password"
ADMIN_NAME="Super Admin"
